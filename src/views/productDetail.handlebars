<section class="product-detail-container">
    <div class="detail-grid">
        <div class="cover-wrapper hover-vinyl">
            <img src="/static/covers/{{product.coverImageSource}}" alt="{{product.name}}">
        </div>
        <div class="product-detail">
            <h1 class="product-title">{{product.name}}</h1>
            <div class="product-info">
                <div class="product-detail-titles">
                    <p><strong>Artista:</strong> {{product.artist}}</p>
                    <p><strong>Precio:</strong><span class="product-price"> ${{product.currentPrice}}</span></p>
                    <p><strong>Categoría:</strong> {{product.category}}</p>
                    <p><strong>Stock:</strong> {{product.stock}} unidades</p>
                </div>
                <div class="product-info">
                    &nbsp;
                    <p>{{product.description}}</p>
                    &nbsp;
                </div>
                <hr>
            </div>
            <div class="product-detail-buttons">
                <div class="quantity-selector">
                    <button class="btn qty-btn minus">-</button>
                    <span class="qty-value">1</span>
                    <button class="btn qty-btn plus">+</button>
                </div>
                <div class="detail-actions">
                    <a class="btn nav-btn" href="/products">Volver al catálogo</a>
                    <button class="add-to-cart btn" data-product-id="{{product._id}}" id="add-to-cart">
                        Agregar al carrito
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>